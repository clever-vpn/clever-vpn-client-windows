<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Clever_Vpn.Pages.HomePage.components.HomeCardLineSelector"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Clever_Vpn.Pages.HomePage.components"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vpn="using:Clever_Vpn_Windows_Kit.Data"
    mc:Ignorable="d">

    <Grid HorizontalAlignment="Center">
        <Button Background="Transparent" BorderThickness="0">
            <Button.Flyout>
                <Flyout x:Name="LineSelectorFlyout" Placement="Bottom" Opening="OnLineSelectorFlyoutOpening">
                    <Border x:Name="LineSelectorPanel" MaxHeight="520" Padding="0" DataContext="{x:Bind Vm, Mode=OneWay}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- Legend: adaptive one-row layout to avoid forced equal-width wrapping -->
                            <StackPanel Grid.Row="0" Margin="12,10,12,6" Orientation="Horizontal" Spacing="14" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                    <TextBlock x:Uid="LineSelectorLegendFactor" FontWeight="SemiBold" TextWrapping="NoWrap"/>
                                    <TextBlock x:Uid="LineSelectorLegendTraffic" TextWrapping="NoWrap"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                    <Image Width="14" Height="14"
                                        Source="{x:Bind local:HomeCardLineSelector.GetRelayIcon(), Mode=OneTime}"
                                        Stretch="Uniform"/>
                                    <TextBlock x:Uid="LineSelectorLegendRelay" TextWrapping="NoWrap"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                    <Image Width="14" Height="14"
                                        Source="{x:Bind local:HomeCardLineSelector.GetUpstreamIcon(), Mode=OneTime}"
                                        Stretch="Uniform"/>
                                    <TextBlock x:Uid="LineSelectorLegendUpstream" TextWrapping="NoWrap"/>
                                </StackPanel>
                            </StackPanel>

                            <ListView
                                Grid.Row="1"
                                x:Name="LineListView"
                                Margin="8,0"
                                HorizontalContentAlignment="Stretch"
                                SelectionMode="Single"
                                IsItemClickEnabled="True"
                                ItemClick="OnLineItemClick">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="vpn:Line">
                                        <Grid Padding="4,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Image Width="20" Height="20"
                                                Grid.Column="0"
                                                Source="{x:Bind local:HomeCardLineSelector.GetLineIconPath(Icon, IconKind), Mode=OneTime}"
                                                Stretch="Uniform" Margin="0,0,12,0"/>

                                            <TextBlock Grid.Column="1" Text="{x:Bind Label}" VerticalAlignment="Center" Margin="0,0,8,0"/>

                                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" HorizontalAlignment="Right">
                                                <TextBlock
                                                    Text="{x:Bind local:HomeCardLineSelector.GetLineFactorText(Factor), Mode=OneTime}"
                                                    Foreground="DeepSkyBlue"
                                                    FontSize="12"
                                                    VerticalAlignment="Center"/>
                                                <Image Width="14" Height="14"
                                                    Source="{x:Bind local:HomeCardLineSelector.GetRelayIcon(), Mode=OneTime}"
                                                    Visibility="{x:Bind local:HomeCardLineSelector.BoolToVisibility(HasRelay), Mode=OneTime}"
                                                    Stretch="Uniform" VerticalAlignment="Center"/>
                                                <Image Width="14" Height="14"
                                                    Source="{x:Bind local:HomeCardLineSelector.GetUpstreamIcon(), Mode=OneTime}"
                                                    Visibility="{x:Bind local:HomeCardLineSelector.BoolToVisibility(HasUpstream), Mode=OneTime}"
                                                    Stretch="Uniform" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>

                            <Grid Grid.Row="2" HorizontalAlignment="Stretch" BorderThickness="0,1,0,0" BorderBrush="LightGray" Margin="12,10,12,10">
                                <StackPanel
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Spacing="16">
                                    <Button x:Name="RefreshButton" Click="OnRefreshLinesClick">
                                        <Grid MinWidth="64">
                                            <TextBlock x:Name="RefreshButtonText" x:Uid="LineSelectorRefresh" HorizontalAlignment="Center"/>
                                            <ProgressRing x:Name="RefreshButtonSpinner" Height="16" Width="16" IsActive="True" Visibility="Collapsed" HorizontalAlignment="Center"/>
                                        </Grid>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>
                </Flyout>
            </Button.Flyout>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
                <Image Width="20" Height="20"
                    Source="{x:Bind GetLineIconSource(Vm.UserInfo, Vm.Lines), Mode=OneWay}"
                    Stretch="Uniform"/>
                <TextBlock Text="{x:Bind GetLineName(Vm.UserInfo, Vm.Lines), Mode=OneWay}" />
                <FontIcon Glyph="&#xE70F;" Foreground="DeepSkyBlue" FontSize="14"/>
            </StackPanel>
        </Button>
    </Grid>

</UserControl>
