<?xml version="1.0" encoding="utf-8"?>
<winuiEx:WindowEx
    x:Class="Clever_Vpn.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:winuiEx="using:WinUIEx"
    xmlns:local="using:Clever_Vpn"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:triggers="using:CommunityToolkit.WinUI"
    xmlns:utils="using:Clever_Vpn.utils"
    xmlns:interactivity="using:Microsoft.Xaml.Interactivity"
    xmlns:behaviors="using:Clever_Vpn.behaviors" 
    xmlns:components="using:Clever_Vpn.components"
    mc:Ignorable="d"
    x:Uid="MainWindow"
    Title="Clever-Vpn">

    <winuiEx:WindowEx.SystemBackdrop >
        <MicaBackdrop />
    </winuiEx:WindowEx.SystemBackdrop>
    <Grid x:Name="RootLayout" Margin="10, 0, 10, 10">
        <Frame x:Name="MainFrame" >
            <interactivity:Interaction.Behaviors>
                <behaviors:FrameNavigateBehavior />
            </interactivity:Interaction.Behaviors>
        </Frame>
        <InfoBar
            x:Name="MainErrorBar"
            IsOpen="False"
            CloseButtonCommand="{x:Bind vm.ClearLastErrorCommand}"
            Severity="Warning"
            x:Uid="MainWindowWarningBar"
            Message="">
            <InfoBar.Content>
                <Grid RowSpacing="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock
                        Grid.Row="0"
                        IsTextSelectionEnabled="True"
                        TextWrapping="Wrap"
                        VerticalAlignment="Top"
                        Text="{x:Bind vm.LastError.FormattedMessage, Mode=OneWay}" />

                    <AppBarButton
                        Grid.Row="1"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Padding="0"
                        Margin="0,-10,0,0"
                        Width="24"
                        Height="36"
                        MinWidth="24"
                        MinHeight="24"
                        Click="OnCopyErrorClick"
                        ToolTipService.ToolTip="Copy error message"
                        IsCompact="True">
                        <AppBarButton.Icon>
                            <FontIcon x:Name="CopyErrorIcon" Glyph="&#xE8C8;" />
                        </AppBarButton.Icon>
                    </AppBarButton>
                </Grid>
            </InfoBar.Content>
        </InfoBar>
         <components:TrayIconView  x:Name="TrayIconView" />
    </Grid>

</winuiEx:WindowEx>
