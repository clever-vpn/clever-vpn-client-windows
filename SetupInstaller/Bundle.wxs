<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
	 xmlns:bal="http://wixtoolset.org/schemas/v4/wxs/bal">
  <Bundle Name="Clever VPN"
		  Manufacturer="Clever VPN Team"
		  Version="$(CleverVpnInstallerVersion)"
		  IconSourceFile="..\Clever-Vpn\Assets\appIcon.ico"
		  UpgradeCode="6A51A83A-1462-40FB-95BD-F39B6AE9026A">

	<Variable Name="UseTestInstallerDownloadBaseUrl"
			  Type="numeric"
			  Value="0"
			  bal:Overridable="yes" />

	<BootstrapperApplication>
	  <bal:WixStandardBootstrapperApplication
		Theme="hyperlinkLicense"
		ThemeFile="Assets\HyperlinkTheme.xml"
		LicenseUrl="https://www.clever-vpn.net/license"
		LogoFile="Assets\SetupLogo.512.png"
		LaunchTarget="[ProgramFiles6432Folder]Clever VPN\Clever-Vpn.exe"
		LaunchWorkingFolder="[ProgramFiles6432Folder]Clever VPN" />
	</BootstrapperApplication>

	<Chain>
	  <MsiPackage Id="MsiX86"
				  SourceFile="$(MsiSourceRoot)\x86\$(Configuration)\en-US\CleverVPN_$(CleverVpnInstallerVersion)_x86.msi"
				  DownloadUrl="$(InstallerDownloadBaseUrl)/CleverVPN_$(CleverVpnInstallerVersion)_x86.msi"
				  Compressed="no"
				  InstallCondition="NOT VersionNT64 AND UseTestInstallerDownloadBaseUrl &lt;&gt; 1" />

	  <MsiPackage Id="MsiX86Test"
				  SourceFile="$(MsiSourceRoot)\x86\$(Configuration)\en-US\CleverVPN_$(CleverVpnInstallerVersion)_x86.msi"
				  CacheId="MsiX86Test-$(CleverVpnInstallerVersion)"
				  DownloadUrl="$(TestInstallerDownloadBaseUrl)/CleverVPN_$(CleverVpnInstallerVersion)_x86.msi"
				  Compressed="no"
				  InstallCondition="NOT VersionNT64 AND UseTestInstallerDownloadBaseUrl = 1" />

	  <MsiPackage Id="MsiX64"
				  SourceFile="$(MsiSourceRoot)\x64\$(Configuration)\en-US\CleverVPN_$(CleverVpnInstallerVersion)_x64.msi"
				  DownloadUrl="$(InstallerDownloadBaseUrl)/CleverVPN_$(CleverVpnInstallerVersion)_x64.msi"
				  Compressed="no"
				  InstallCondition="VersionNT64 AND NOT VersionNTARM64 AND UseTestInstallerDownloadBaseUrl &lt;&gt; 1" />

	  <MsiPackage Id="MsiX64Test"
				  SourceFile="$(MsiSourceRoot)\x64\$(Configuration)\en-US\CleverVPN_$(CleverVpnInstallerVersion)_x64.msi"
				  CacheId="MsiX64Test-$(CleverVpnInstallerVersion)"
				  DownloadUrl="$(TestInstallerDownloadBaseUrl)/CleverVPN_$(CleverVpnInstallerVersion)_x64.msi"
				  Compressed="no"
				  InstallCondition="VersionNT64 AND NOT VersionNTARM64 AND UseTestInstallerDownloadBaseUrl = 1" />

	  <MsiPackage Id="MsiArm64"
				  SourceFile="$(MsiSourceRoot)\ARM64\$(Configuration)\en-US\CleverVPN_$(CleverVpnInstallerVersion)_ARM64.msi"
				  DownloadUrl="$(InstallerDownloadBaseUrl)/CleverVPN_$(CleverVpnInstallerVersion)_ARM64.msi"
				  Compressed="no"
				  InstallCondition="VersionNTARM64 AND UseTestInstallerDownloadBaseUrl &lt;&gt; 1" />

	  <MsiPackage Id="MsiArm64Test"
				  SourceFile="$(MsiSourceRoot)\ARM64\$(Configuration)\en-US\CleverVPN_$(CleverVpnInstallerVersion)_ARM64.msi"
				  CacheId="MsiArm64Test-$(CleverVpnInstallerVersion)"
				  DownloadUrl="$(TestInstallerDownloadBaseUrl)/CleverVPN_$(CleverVpnInstallerVersion)_ARM64.msi"
				  Compressed="no"
				  InstallCondition="VersionNTARM64 AND UseTestInstallerDownloadBaseUrl = 1" />
	</Chain>
  </Bundle>
</Wix>
